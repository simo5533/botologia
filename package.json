{
  "name": "botoologia-desktop-root",
  "private": true,
  "description": "Point d'entrée : le code Next.js est dans BoTooLogIA/BoTooLogIA/. Les scripts npm délèguent vers ce dossier.",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@prisma/client-runtime-utils": "7.4.0",
    "autoprefixer": "10.4.20",
    "next": "14.2.35",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15"
  },
  "scripts": {
    "postinstall": "npm run install:project",
    "dev": "npm run dev --prefix BoTooLogIA/BoTooLogIA",
    "build": "npm run install:project && npm run build --prefix BoTooLogIA/BoTooLogIA",
    "vercel:build": "npm run build && node scripts/vercel-copy-next.cjs",
    "start": "npm run start --prefix BoTooLogIA/BoTooLogIA",
    "typecheck": "npm run typecheck --prefix BoTooLogIA/BoTooLogIA",
    "test": "npm run test --prefix BoTooLogIA/BoTooLogIA",
    "lint": "npm run lint --prefix BoTooLogIA/BoTooLogIA",
    "test:coverage": "npm run test:coverage --prefix BoTooLogIA/BoTooLogIA",
    "test:e2e": "npm run test:e2e --prefix BoTooLogIA/BoTooLogIA",
    "check:all": "npm run check:all --prefix BoTooLogIA/BoTooLogIA",
    "install:project": "npm install --prefix BoTooLogIA/BoTooLogIA"
  }
}
